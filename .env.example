# Copy this file to .env and fill the values before running the server

GMAIL_USER=your.email@gmail.com
# Generate an App Password in Google Account -> Security -> App passwords
# Example: GMAIL_APP_PASSWORD=abcd efgh ijkl mnop (no spaces)
GMAIL_APP_PASSWORD=
TO_EMAIL=your.email@gmail.com
# Port the backend should listen on
PORT=3004

# Option 1: SendGrid (recommended) - set this to use the SendGrid API instead of SMTP
# Get an API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
